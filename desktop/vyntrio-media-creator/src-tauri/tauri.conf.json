{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vyntrio Media Creator",
  "version": "0.2.0",
  "identifier": "xyz.vyntrio.media-creator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vyntrio Media Creator",
        "width": 920,
        "height": 640,
        "minWidth": 800,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis"],
    "category": "Utility",
    "shortDescription": "Write Vyntrio install media to USB",
    "longDescription": "Native Vyntrio Media Creator for selecting a dual-mode (BIOS+UEFI) install image and writing it to removable storage.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  }
}
