# Vyntrio OS — Environment Variables (Example)
#
# Copy to `.env` at the repository root. Never commit `.env`.
# See docs/API_CONVENTIONS.md for full reference.

# Runtime
VYNTRIO_ENV=development
VYNTRIO_LOG_LEVEL=debug

# API service (cmd/api — Slice 1)
VYNTRIO_API_HOST=127.0.0.1
VYNTRIO_API_PORT=8080
VYNTRIO_API_READ_TIMEOUT=15s
VYNTRIO_API_WRITE_TIMEOUT=15s
VYNTRIO_API_IDLE_TIMEOUT=60s

# Build metadata (optional — override at link time via Makefile later)
VYNTRIO_VERSION=0.2.0-dev
VYNTRIO_BUILD_COMMIT=unknown

# Frontend dev server (Slice 3+ — not used yet)
# VYNTRIO_WEB_HOST=127.0.0.1
# VYNTRIO_WEB_PORT=5173

# Data directory (Slice 2+ — SQLite path)
# VYNTRIO_DATA_DIR=/var/lib/vyntrio

# TLS (production — later)
# VYNTRIO_TLS_CERT=
# VYNTRIO_TLS_KEY=

# See docs/17_SECURITY.md for secret handling policy.
